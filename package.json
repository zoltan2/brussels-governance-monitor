{
  "name": "brussels-governance-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Making Brussels governance visible, verifiable, and understandable",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "velite": "velite",
    "dev": "velite && next dev",
    "build": "velite --clean && next build && pagefind --site .next/server/app --output-path public/pagefind",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,mdx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:digest": "tsx scripts/test-digest.ts",
    "generate-digest": "tsx scripts/generate-digest.ts",
    "qr:cafe": "tsx scripts/generate-qr-cafe-numerique.ts",
    "assets:merci-cafe": "tsx scripts/optimize-merci-cafe-assets.ts",
    "magazine:preview": "tsx scripts/preview-magazine.ts",
    "magazine:build": "tsx scripts/build-magazine.ts",
    "chat:generate-suggested": "tsx scripts/generate-suggested-answers.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@appsignal/nodejs": "^3.7.4",
    "@react-email/components": "^1.0.7",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.6.1",
    "autoprefixer": "^10.4.24",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.574.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.1",
    "stripe": "^22.0.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "velite": "^0.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^5.1.3",
    "dotenv": "^17.2.4",
    "pagefind": "^1.4.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  }
}
