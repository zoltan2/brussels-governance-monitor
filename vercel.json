{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "rewrites": [
    { "source": "/pagefind/:path*", "destination": "/api/pagefind/:path*" }
  ],
  "crons": [
    {
      "path": "/api/cron/prepare-digest",
      "schedule": "0 20 * * 0"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 7 * * 1"
    }
  ]
}
