# Brussels Governance Monitor — Environment Variables
# Copy this file to .env.local and fill in the values

# Resend (email notifications — S2+)
RESEND_API_KEY=

# Umami Analytics (free cloud: https://cloud.umami.is)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Site URL (for OG images, canonical URLs)
# Set to your production URL on Vercel (e.g. https://governance.brussels)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub API (for review page publish/reject actions)
# Token needs repo write access (Contents API)
GITHUB_TOKEN=
GITHUB_REPO=zoltan2/brussels-governance-monitor

# Auth.js (session signing & encryption)
# Generate with: npx auth secret
AUTH_SECRET=

# Cron secret (Vercel Cron authorization)
# Generate with: openssl rand -base64 32
CRON_SECRET=

# Admin credentials (single admin for /review page)
# Email is also used for watch digest notifications
ADMIN_EMAIL=
# Generate hash with: node -e "require('bcryptjs').hash('your-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=

# AppSignal (error monitoring — https://appsignal.com)
APPSIGNAL_PUSH_API_KEY=

# Digest generation (Phase 2 — scripts/generate-digest.ts)
DEEPL_API_KEY=
ANTHROPIC_API_KEY=

# Chatbot (feature/chatbot — /api/chat)
# ANTHROPIC_API_KEY is reused for provider="anthropic"

# Kill-switch — set to 'true' to enable the ChatWidget on the site.
# Exposed to the client by Next.js (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_CHATBOT_ENABLED=

# Salt for the session hash in chat usage logs (SHA-256(secret|ip|YYYY-MM-DD)).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHAT_SESSION_SECRET=

# Stripe (feature/chatbot — /api/chat/checkout)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# Upstash Redis — persistent chat telemetry (/admin/chat, cron digest).
# When unset: the code falls back to ./logs/*.jsonl on dev, and to stdout-only on
# Vercel (admin page shows 0 entries). Add the Upstash marketplace integration
# in Vercel to auto-inject these two vars.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
